{
  "name": "@x-mix/client",
  "version": "0.0.20",
  "description": "JavaScript client for the X Mix program",
  "sideEffects": false,
  "module": "./dist/src/index.mjs",
  "main": "./dist/src/index.js",
  "types": "./dist/types/src/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/src/index.mjs",
      "require": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "circuits"
  ],
  "scripts": {
    "copy-circuits": "./copy-circuits.sh",
    "build": "rimraf dist && tsup && tsc -p ./tsconfig.declarations.json",
    "build:docs": "typedoc",
    "test": "ava",
    "build:test": "pnpm build && pnpm test",
    "lint": "eslint --ext js,ts,tsx src",
    "lint:fix": "eslint --fix --ext js,ts,tsx src",
    "format": "prettier --check src test",
    "format:fix": "prettier --write src test",
    "prepublishOnly": "pnpm copy-circuits && pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x-mix/x-mix.git"
  },
  "bugs": {
    "url": "https://github.com/x-mix/x-mix/issues"
  },
  "homepage": "https://github.com/x-mix/x-mix#readme",
  "license": "MIT",
  "devDependencies": {
    "@ava/typescript": "^4.1.0",
    "@solana/eslint-config-solana": "^3.0.3",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "ava": "^6.1.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "tsup": "^8.1.2",
    "typedoc": "^0.25.12",
    "typescript": "^5.9.3"
  },
  "ava": {
    "nodeArguments": [
      "--no-warnings"
    ],
    "typescript": {
      "compile": false,
      "rewritePaths": {
        "test/": "dist/test/"
      }
    },
    "timeout": "2m",
    "workerThreads": false
  },
  "packageManager": "pnpm@9.1.0",
  "dependencies": {
    "@solana-program/compute-budget": "^0.11.0",
    "@solana-program/system": "^0.10.0",
    "@solana-program/token": "^0.9.0",
    "@solana-program/token-2022": "^0.6.1",
    "@solana/compat": "^5.0.0",
    "@solana/kit": "^6.3.0",
    "@solana/spl-account-compression": "^0.2.1",
    "@solana/web3.js": "^1.98.4",
    "@types/circomlibjs": "^0.1.6",
    "@types/snarkjs": "^0.7.9",
    "circomlibjs": "^0.1.7",
    "ffjavascript": "^0.3.1",
    "snarkjs": "^0.7.5"
  }
}
